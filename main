    local totalSeconds = nil

    local function parseTime(str)
        local m, s = str:match("(%d+):(%d+)")
        if m and s then
            return tonumber(m) * 60 + tonumber(s)
        end
    end

    local function findCrankTime()
        local baseplate = workspace:FindFirstChild("Baseplates")
        if not baseplate then return end

        for _, bp in ipairs(baseplate:GetChildren()) do
            local enemyBase = bp:FindFirstChild("EnemyBase")
            if enemyBase then
                local bridge = enemyBase:FindFirstChild("Bridge")
                if bridge then
                    local controlPart = bridge:FindFirstChild("BridgeControl")
                    if controlPart then
                        local part = controlPart:FindFirstChild("Part")
                        if part then
                            local gui = part:FindFirstChild("BillboardGui")
                            if gui and gui.Enabled then
                                local label = gui:FindFirstChild("TextLabel")
                                if label then
                                    return parseTime(label.Text)
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    local startTime = tick()
    while tick() - startTime < 3 and not totalSeconds do
        totalSeconds = findCrankTime()
        task.wait(0.3)
    end

    if not totalSeconds then
        totalSeconds = 600
    end

    while totalSeconds > 0 do
        local m = math.floor(totalSeconds / 60)
        local s = totalSeconds % 60

        t.Text = string.format("Crank will available in %02d:%02d", m, s)

        totalSeconds -= 1
        task.wait(1)
    end

    t.Text = "Crank is available"
