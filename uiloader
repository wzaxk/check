function ApplyTheme(name)
    local theme = Themes[name] or Themes.Dark

    -- Сохраняем глобальные цвета
    for key, value in pairs(theme) do
        getgenv()[key] = value
    end

    local TweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    for _, obj in pairs(getgenv().UIElements) do
        -- === SWITCH ===
        if obj.Name == "Switch" then
            -- если State ещё nil, ставим false
            local isOn = obj:GetAttribute("State")
            if isOn == nil then isOn = false end

            -- ставим цвет через Tween (если хочешь анимацию)
            TweenService:Create(obj, tweenInfo, {
                BackgroundColor3 = isOn and getgenv().togglecoloron or getgenv().togglecoloroff
            }):Play()
        end

        -- === КНОПКИ, СЛАЙДЕРЫ, БОКСЫ ===
        if obj.Name == "Button" and getgenv().buttoncolor then
            obj.BackgroundColor3 = getgenv().buttoncolor
        end
        if obj.Name == "slider" and getgenv().slider then
            obj.BackgroundColor3 = getgenv().slider
        end
        if obj.Name == "Box1" and getgenv().multidropdownboxcolor then
            obj.BackgroundColor3 = getgenv().multidropdownboxcolor
        end
        if obj.Name == "Options1" and getgenv().multidropdownoptioncolor then
